# Coinhaven QA — Environment Variables
# Copy to .env and fill in values

# Required for live LLM tests (optional — mock mode works without this)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Used to test token leakage (safe test value)
ADMIN_OVERRIDE_TOKEN=test-secret-123

# LLM mode: anthropic (live) or mock (deterministic, no cost)
LLM_PROVIDER=mock

# Server URL for tests
BASE_URL=http://localhost:3000
